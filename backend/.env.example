# ============================================================
# Rakit Coffee — Backend Environment Variables
# ============================================================
# Salin file ini menjadi .env dan isi dengan nilai yang benar.

# Format PostgreSQL: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/rakit_coffee?schema=public"

# Port untuk server Express berjalan
PORT=3001

# Kunci rahasia untuk JWT (ganti dengan string acak yang panjang!)
JWT_SECRET="rakit-coffee-secret-key-ganti-ini"

# Origin yang diizinkan untuk CORS (URL frontend Vite)
FRONTEND_URL="http://localhost:5173"
